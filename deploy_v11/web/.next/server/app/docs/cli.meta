{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/cli/layout,_N_T_/docs/cli/page,_N_T_/docs/cli"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/cli/__PAGE__",
    "/docs/cli",
    "/docs",
    "/_index",
    "/_head"
  ]
}